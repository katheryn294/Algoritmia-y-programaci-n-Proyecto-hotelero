        "        \"        actual_cols = getattr(actual, 'n_features_in_', None)\\n\",\n",
        "        \"\\n\",\n",
        "        \"        if expected_cols is not None and actual_cols is not None:\\n\",\n",
        "        \"            if expected_cols != actual_cols:\\n\",\n",
        "        \"                return False, f\\\"Model feature count mismatch: expected {expected_cols} columns, actual accepts {actual_cols}\\\"\\n\",\n",
        "        \"        elif expected_cols is not None and actual_cols is None:\\n\",\n",
