        "        \"            return False, f'Expected {expected}\\\\n but got {actual}'\\n\",\n",
        "        \"        return True, \\\"\\\"\\n\",\n",
        "        \"\\n\",\n",
        "        \"    else:\\n\",\n",
        "        \"        if expected != actual:\\n\",\n",
