        "        \"\\n\",\n",
        "        \"    contents = response.json()\\n\",\n",
        "        \"    file_map = {f['name']: f for f in contents if f['type'] == 'file'}\\n\",\n",
        "        \"\\n\",\n",
        "        \"\\n\",\n",
        "        \"    usecase_generator_errors = []\\n\",\n",
