        "        \"\\n\",\n",
        "        \"def compare_outputs(expected, actual):\\n\",\n",
        "        \"    if pd is not None and isinstance(expected, pd.DataFrame):\\n\",\n",
        "        \"        if not isinstance(actual, pd.DataFrame):\\n\",\n",
