        "        \"        if file_info.get('type') == 'file':\\n\",\n",
        "        \"            match = re.match(r'answer-(.+)\\\\.py$', file_info['name'])\\n\",\n",
        "        \"            if match:\\n\",\n",
        "        \"                total_answers += 1\\n\",\n",
