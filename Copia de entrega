        "        \"\\n\",\n",
        "        \"def get_repo_info(url):\\n\",\n",
        "        \"    \\\"\\\"\\\"Extracts the owner and repo name from a GitHub URL.\\\"\\\"\\\"\\n\",\n",
        "        \"    match = re.search(r'https://github\\\\.com/([^/]+)/([^/]+)', url)\\n\",\n",
        "        \"    if match:\\n\",\n",
        "        \"        owner = match.group(1)\\n\",\n",
        "        \"        repo = match.group(2).replace('.git', '')\\n\",\n",
        "        \"        return owner, repo\\n\",\n",
        "        \"    return None, None\\n\",\n",
        "        \"\\n\",\n",
        "        \"def to_raw_url(url):\\n\",\n",
        "        \"    if not url or not url.startswith('http'):\\n\",\n",
        "        \"        return url\\n\",\n",
        "        \"    match = re.match(r'https://github\\\\.com/([^/]+)/([^/]+)/blob/([^/]+)/(.*)', url)\\n\",\n",
        "        \"    if match:\\n\",\n",
        "        \"        owner, repo, branch, path = match.groups()\\n\",\n",
        "        \"        return f\\\"https://raw.githubusercontent.com/{owner}/{repo}/{branch}/{path}\\\"\\n\",\n",
