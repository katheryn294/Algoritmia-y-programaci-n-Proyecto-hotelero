        "        \"        return True, \\\"\\\"\\n\",\n",
        "        \"\\n\",\n",
        "        \"def load_question_map(csv_path):\\n\",\n",
        "        \"    \\\"\\\"\\\"Loads the mapping between question_id (column 0) and usecase_generator (column 2).\\\"\\\"\\\"\\n\",\n",
        "        \"    q_map = {}\\n\",\n",
        "        \"    with open(csv_path, 'r', encoding='utf-8') as f:\\n\",\n",
